{
	"name": "@stackory/monosync",
	"version": "1.0.0",
	"type": "module",
	"bin": {
		"monosync": "./dist/bin.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"sideEffects": false,
	"scripts": {
		"dev": "tsx src/bin.ts",
		"build": "tsc -p tsconfig.build.json",
		"clean": "rimraf ./node_modules dist",
		"check:test": "vitest --watch=false",
		"check:lint": "biome check --write",
		"check:type": "tsc -p ./tsconfig.json --noEmit",
		"check:dep": "depcruise --config .dependency-cruiser.mjs src"
	},
	"dependencies": {
		"semver": "7.7.2",
		"yaml": "2.9.0"
	},
	"devDependencies": {
		"@types/node": "24.10.1",
		"@types/semver": "7.7.1"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/j-xzy/stackor",
		"directory": "packages/monosync"
	}
}
{
	"name": "stackory",
	"private": true,
	"scripts": {
		"nx": "NX_LOAD_DOT_ENV_FILES=false nx",
		"clean": "nx reset && nx run-many --target=clean --all && rimraf .nx && rimraf node_modules",
		"check:affected": "nx affected --targets=check:lint,check:test,check:type,check:dep,build --verbose",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"changeset:release": "pnpm nx run-many -t build --skip-nx-cache && changeset publish",
		"monosync": "tsx packages/monosync/src/bin.ts",
		"monosync:update": "tsx packages/monosync/src/bin.ts --auto --write",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@changesets/cli": "2.31.0",
		"@infra/dep-presets": "workspace:*",
		"@infra/tsconfig-presets": "workspace:*",
		"@stackory/monosync": "workspace:*",
		"dependency-cruiser": "17.4.0",
		"lefthook": "2.1.6",
		"nx": "22.7.2",
		"rimraf": "6.1.3",
		"tsc-alias": "1.8.17",
		"tsx": "4.21.0",
		"typescript": "6.0.3",
		"vitest": "4.1.6"
	},
	"engines": {
		"node": ">=24.0.0 <25.0.0"
	},
	"packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
